# Copy this file to .env.local and fill in your key.
# Get a Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the default model (gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Get a key at https://apitube.io — note trial/free-tier keys redact article
# URLs, images, and source domains behind "[Upgrade subscription plan]"
# placeholders in the response (handled gracefully in lib/news.ts, but links
# and images won't actually work until the plan is upgraded).
NEWS_API_KEY=

# Supabase project (Settings -> API in your Supabase dashboard). Required —
# the global proxy/middleware crashes on every request without these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
